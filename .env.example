# Google Analytics 4
GA4_PROPERTY_ID=G-EZQRVJY38R

# Google Service Account JSON ( Service Account key from Google Cloud Console )
# Download from: Google Cloud Console → APIs & Services → Credentials → Service Accounts → Keys
# Format: Full JSON content as string
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."...}'

# Site
NEXT_PUBLIC_SITE_URL=https://ezmeo.com
NEXT_PUBLIC_BASE_URL=https://ezmeo.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_ROLE_KEY=xxxx

# Plausible CE (optional - if set, dashboard traffic metrics come from Plausible)
PLAUSIBLE_BASE_URL=https://analytics.yourdomain.com
PLAUSIBLE_SITE_ID=ezmeo.com
PLAUSIBLE_STATS_API_KEY=plausible_api_key
